// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Product {
  id            String   @id @default(cuid())
  name          String
  sku           String   @unique
  description   String?
  category      String
  unit          String
  salesChannel  String   @default("both") // retail | wholesale | both
  retailPrice   Float
  wholesalePrice Float
  costPrice     Float
  currentStock  Int      @default(0)
  minStock      Int      @default(10)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orderItems    OrderItem[]
  stockMovements StockMovement[]
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  type      String   @default("retail") // retail | wholesale
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]
}

model Order {
  id          String   @id @default(cuid())
  orderNumber String   @unique
  customerId  String?
  type        String   // retail | wholesale
  status      String   @default("pending") // pending | completed | cancelled
  subtotal    Float
  tax         Float    @default(0)
  discount    Float    @default(0)
  total       Float
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer    Customer? @relation(fields: [customerId], references: [id])
  items       OrderItem[]
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  total     Float

  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model StockMovement {
  id        String   @id @default(cuid())
  productId String
  type      String   // in | out
  quantity  Int
  reason    String?
  reference String?
  createdAt DateTime @default(now())

  product   Product @relation(fields: [productId], references: [id])
}

model Supplier {
  id          String   @id @default(cuid())
  name        String
  phone       String?
  address     String?
  productType String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
